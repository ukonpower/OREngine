import { Renderer } from "../../src";

describe( 'Renderer', () => {

	let canvas: HTMLCanvasElement;
	let renderer: Renderer;

	beforeAll( () => {

		canvas = document.createElement( 'canvas' );

		renderer = new Renderer( {
			canvas: canvas
		} );

	} );

	describe( 'Renderer', () => {

		it( 'should be has canvas', () => {

			expect( renderer.canvas ).not.toBeNull();

		} );

	} );

} );
